from pygame import *
mixer.init()
font.init()

win_width = 1000
win_height = 700
window=display.set_mode((win_width, win_height))
display.set_caption('Пинг-Понг')
background=transform.scale(image.load('fon.jpg'), (1000, 700))
FPS =100                                       
clock = time.Clock()
game = True
finish = False
while game == True:
    for e in event.get():
        if e.type == QUIT:
            game = False
    if finish != True:
        window.blit(background, (0,0))

    display.update()
    clock.tick(FPS)
