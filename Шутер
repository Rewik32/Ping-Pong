from pygame import *
from random import*
from time import time as timer
mixer.init()
font.init()

mixer.music.load('space.ogg')
mixer.music.play()
fire = mixer.Sound('fire.ogg')
win_width = 1000
win_height = 700
window=display.set_mode((win_width, win_height))
display.set_caption('Шутер')
background=transform.scale(image.load('space2.jpg'), (1000, 700))
FPS =100                                       
clock = time.Clock()
game = True
finish = False
class GameSprite(sprite.Sprite):
    def __init__(self, q_image, x, y, speed, size_x, size_y):
        super().__init__()
        self.image = transform.scale(image.load(q_image), (size_x, size_y))
        self.speed = speed
        self.rect = self.image.get_rect()
        self.rect.x = x
        self.rect.y = y
        self.size_x = size_x
        self.size_y = size_y
    def reset(self):
        window.blit(self.image, (self.rect.x, self.rect.y))
class Player(GameSprite):
    def update(self):
        keys = key.get_pressed()
        if keys[K_LEFT] and self.rect.x > 5:
            self.rect.x -= self.speed
        if keys[K_RIGHT] and self.rect.x < win_width - 80:
            self.rect.x += self.speed
    def fire(self):
        bullet = Bullet('bullet.png', self.rect.centerx - 10, self.rect.top, 5, 20, 20)
        bullets.add(bullet)
lost = 0
score = 0
num_fire = 0
life = 3
rel_time = False
class Enemy(GameSprite):
    def update(self):
        self.rect.y += self.speed
        global lost
        if self.rect.y>=win_height:
            lost +=1 
            self.rect.x = randint(50,650)
            self.rect.y = -20
monsters = sprite.Group()
class Asteroid(GameSprite):
    def update(self):
        self.rect.y += self.speed
        global lost
        if self.rect.y>=win_height:
            lost +=1 
            self.rect.x = randint(50,650)
            self.rect.y = -20
asteroids = sprite.Group()
class Bullet(GameSprite):
    def update(self): 
        self.rect.y -= self.speed
        if self.rect.y<0:
            self.kill()
bullets = sprite.Group()

for i in range(1, 3):
    monster = Enemy('ufo.png',  randint(50, 950), randint(-400, -200), randint(1, 2), 50, 50)
    monsters.add(monster)
for i in range(1, 3):
    asteroid = Asteroid('asteroid.png',  randint(50, 950), randint(-400, -200), randint(1, 2), 50, 50)
    asteroids.add(asteroid)
count_win = 0 
font2 = font.SysFont('Arial', 36)
font1 = font.SysFont('Arial', 36)
font3 = font.SysFont('Arial', 80)
font4 = font.SysFont('Arial', 80)
hero = Player('weapon1.png', 65, 635, 5, 70, 70)
while game == True:
    for e in event.get():
        if e.type == QUIT:
            game = False
        elif e.type == KEYDOWN:
            if e.key == K_SPACE:
                if num_fire < 5 and rel_time == False:
                    num_fire+=1
                    hero.fire()
                    fire.play()
                if num_fire >= 5 and rel_time == False:
                    last_time = timer()
                    rel_time = True
            
    if finish != True:
        window.blit(background, (0,0))
        monsters.draw(window)
        monsters.update()
        asteroids.draw(window)
        asteroids.update()
        hero.reset()
        hero.update()
        text_lose = font2.render('Пропущено:'+ str(lost), 1, (255, 255, 255))
        text_count = font1.render('Счёт:'+ str(score), 1, (255, 255, 255))
        win = font3.render('Вы выиграли!', 1, (255, 255, 255))
        lose = font4.render('Вы проиграли!', 1, (255, 255, 255))
        bullets.draw(window)
        bullets.update()
        window.blit(text_lose, (10, 50))
        window.blit(text_count, (10, 10))
        sprite_list = sprite.groupcollide(monsters, bullets, True, True)
        for i in sprite_list:
            score+=1
            monster = Enemy('ufo.png',  randint(50, 950), randint(-400, -200), randint(1, 2), 50, 50)
            monsters.add(monster)
        sprite_list = sprite.groupcollide(asteroids, bullets, True, True)
        for i in sprite_list:
            score+=1
            asteroid = Asteroid('asteroid.png',  randint(50, 950), randint(-400, -200), randint(1, 2), 50, 50)
            asteroids.add(asteroid)
        if score == 10:
            window.blit(win, (250, 300))
            finish = True
        if  sprite.spritecollide(hero, monsters, False) or sprite.spritecollide(hero, asteroids, False):
            sprite.spritecollide(hero, asteroids, True)
            sprite.spritecollide(hero, monsters, True)
            life -= 1
        if life == 0 or lost >= 3:
            finish = True 
            window.blit(lose, (250, 300))
        if rel_time==True:
            now_time = timer()
            if now_time - last_time <3:
                reload = font2.render('Слишком много пуль', 1, (150, 0, 0))
                window.blit(reload, (300, 500))
            else:
                num_fire = 0
                rel_time = False
        if life == 3:
            life_color = (0, 150, 0)
        if life == 2:
            life_color = (150, 150, 0)
        if life == 1:
            life_color = (150, 0, 0)
        text_life = font1.render('Жизни:'+str(life), 1, life_color)
        window.blit(text_life, (10, 90))
    else:
        finish = False
        score=0
        lost=0
        for b in bullets:
            b.kill()
        for m in monsters:
            m.kill()
        for a in asteroids:
            a.kill()
        num_fire = 0
        life = 3
        time.delay(3000)
        for i in range(1, 3):
            monster = Enemy('ufo.png',  randint(50, 950), randint(-400, -200), randint(1, 2), 50, 50)
            monsters.add(monster)
        for i in range(1, 3):
            asteroid = Asteroid('asteroid.png',  randint(50, 950), randint(-400, -200), randint(1, 2), 50, 50)
            asteroids.add(asteroid)
    display.update()
    clock.tick(FPS)
